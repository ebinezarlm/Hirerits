---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import CTASection from '../components/CTASection.astro';
import { generateBreadcrumbSchema } from '../utils/schema';

const seo = {
  title: 'Job Seekers - Explore Global Career Opportunities',
  description: 'Submit your resume and explore global career opportunities across India, North America, Europe, Middle East, and APAC. Mid-level to leadership roles.',
  keywords: 'job opportunities, career opportunities, submit resume, global jobs, job search',
  canonical: '/job-seekers',
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://hireritz.com/' },
  { name: 'Job Seekers', url: 'https://hireritz.com/job-seekers' },
]);
---

<PageLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  schema={[breadcrumbSchema]}
>
  <PageHero
    title="Explore Global Career Opportunities"
    lead="Submit your resume and connect with opportunities across India, North America, Europe, Middle East, and APAC. From mid-level positions to leadership roles."
    image="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=800&q=80"
    imageAlt="Career and growth"
  />

  <section class="section section-light">
    <div class="container">
        <div class="content-grid">
          <div class="content-main">
            <h2>Why Work With Hire Ritz?</h2>
            <p>
              As a job seeker, partnering with Hire Ritz gives you access to exclusive 
              opportunities across multiple industries and global markets. We work with 
              leading organizations to fill positions from mid-level to C-suite.
            </p>
            
            <h3>What We Offer</h3>
            <ul>
              <li><strong>Global Opportunities:</strong> Access to positions across India, North America, Europe, Middle East, and APAC</li>
              <li><strong>Multiple Industries:</strong> IT, Healthcare, Pharma, BFSI, Retail, Manufacturing, Telecom, and more</li>
              <li><strong>Career Levels:</strong> Mid-level, senior, and executive positions</li>
              <li><strong>Personalized Service:</strong> Dedicated consultants who understand your career goals</li>
              <li><strong>Confidentiality:</strong> Your information is kept confidential until you're ready to proceed</li>
              <li><strong>Career Guidance:</strong> Insights into market trends, compensation, and career paths</li>
            </ul>
            
            <h3>How It Works</h3>
            <div class="process-steps">
              <div class="process-step">
                <div class="step-number">1</div>
                <div class="step-content">
                  <h4>Submit Your Resume</h4>
                  <p>Fill out the form below with your details and upload your resume. We'll review your profile and get in touch.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-number">2</div>
                <div class="step-content">
                  <h4>Initial Consultation</h4>
                  <p>We'll have a conversation to understand your career goals, preferences, and what you're looking for.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-number">3</div>
                <div class="step-content">
                  <h4>Matching Opportunities</h4>
                  <p>We'll match you with relevant opportunities from our client base and present them to you.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-number">4</div>
                <div class="step-content">
                  <h4>Interview Support</h4>
                  <p>We'll prepare you for interviews, provide feedback, and guide you through the process.</p>
                </div>
              </div>
              <div class="process-step">
                <div class="step-number">5</div>
                <div class="step-content">
                  <h4>Offer & Onboarding</h4>
                  <p>We'll help with offer negotiation and ensure a smooth transition to your new role.</p>
                </div>
              </div>
            </div>
            
            <h3>Global Regions We Serve</h3>
            <div class="regions-list">
              <div class="region-item">🇮🇳 India</div>
              <div class="region-item">🇺🇸 North America</div>
              <div class="region-item">🇪🇺 Europe</div>
              <div class="region-item">🇦🇪 Middle East</div>
              <div class="region-item">🌏 APAC</div>
            </div>
          </div>
          
          <aside class="content-sidebar">
            <div class="resume-form-card">
              <h3>Submit Your Resume</h3>
              <form class="resume-form" data-validate data-form-type="resume">
                <div class="form-group">
                  <label for="name">Full Name *</label>
                  <input type="text" id="name" name="name" required />
                </div>
                
                <div class="form-group">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required />
                </div>
                
                <div class="form-group">
                  <label for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" />
                </div>
                
                <div class="form-group">
                  <label for="current-role">Current Role</label>
                  <input type="text" id="current-role" name="current_role" />
                </div>
                
                <div class="form-group">
                  <label for="experience">Years of Experience</label>
                  <select id="experience" name="experience">
                    <option value="">Select</option>
                    <option value="0-2">0-2 years</option>
                    <option value="3-5">3-5 years</option>
                    <option value="6-10">6-10 years</option>
                    <option value="11-15">11-15 years</option>
                    <option value="15+">15+ years</option>
                  </select>
                </div>
                
                <div class="form-group">
                  <label for="industry">Industry</label>
                  <select id="industry" name="industry">
                    <option value="">Select</option>
                    <option value="it">IT</option>
                    <option value="healthcare">Healthcare</option>
                    <option value="pharma">Pharma</option>
                    <option value="bfsi">BFSI</option>
                    <option value="retail">Retail</option>
                    <option value="manufacturing">Manufacturing</option>
                    <option value="telecom">Telecom</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                
                <div class="form-group">
                  <label for="resume">Upload Resume *</label>
                  <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" required />
                  <small>PDF, DOC, or DOCX (Max 5MB)</small>
                </div>
                
                <div class="form-group">
                  <label for="message">Additional Information</label>
                  <textarea id="message" name="message" rows="4"></textarea>
                </div>
                
                <button type="submit" class="btn btn-primary w-full">Submit Resume</button>
              </form>
            </div>
          </aside>
        </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
  <CTASection
    title="Ready to Take the Next Step in Your Career?"
    description="Submit your resume today and let us help you find your next opportunity."
    primaryCTA={{
      text: 'Submit Resume',
      href: '#resume-form',
    }}
  />
    </div>
  </section>
</PageLayout>

<style>
  .page-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-light);
    max-width: 800px;
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-2xl);
  }
  
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: var(--spacing-2xl);
  }
  
  .content-main h2 {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }
  
  .content-main h3 {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
  }
  
  .content-main ul {
    margin-bottom: var(--spacing-lg);
  }
  
  .content-main li {
    margin-bottom: var(--spacing-sm);
    line-height: var(--line-height-relaxed);
  }
  
  .process-steps {
    margin: var(--spacing-xl) 0;
  }
  
  .process-step {
    display: flex;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
    align-items: flex-start;
  }
  
  .step-number {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
  }
  
  .step-content h4 {
    margin-bottom: var(--spacing-xs);
    color: var(--color-primary);
  }
  
  .step-content p {
    margin: 0;
    color: var(--color-text-light);
  }
  
  .regions-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin: var(--spacing-lg) 0;
  }
  
  .region-item {
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-bg-light);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-medium);
    border: 1px solid var(--color-border);
  }
  
  .resume-form-card {
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-lg));
    background: var(--color-bg-light);
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }
  
  .resume-form-card h3 {
    margin-bottom: var(--spacing-lg);
    color: var(--color-primary);
  }
  
  .form-group {
    margin-bottom: var(--spacing-lg);
  }
  
  .form-group label {
    display: block;
    margin-bottom: var(--spacing-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
  }
  
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-family: inherit;
  }
  
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(26, 86, 219, 0.1);
  }
  
  .form-group small {
    display: block;
    margin-top: var(--spacing-xs);
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }
  
  .form-group input.error,
  .form-group select.error,
  .form-group textarea.error {
    border-color: var(--color-error);
  }
  
  .error-message {
    display: block;
    margin-top: var(--spacing-xs);
    font-size: var(--font-size-sm);
    color: var(--color-error);
  }
  
  .form-success,
  .form-error {
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-lg);
  }
  
  .form-success {
    background: #d1fae5;
    color: #065f46;
  }
  
  .form-error {
    background: #fee2e2;
    color: #991b1b;
  }
  
  @media (max-width: 968px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    
    .resume-form-card {
      position: static;
    }
  }
  
  @media (max-width: 768px) {
    .page-subtitle {
      font-size: var(--font-size-lg);
    }
  }
</style>
