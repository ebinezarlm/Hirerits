---

<PageLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  schema={[executiveSearchSchema, globalStaffingSchema]}
>
  <section id="hero" class="scroll-section">
    <Hero
      title="Global Recruitment & Staffing Solutions"
      subtitle="Trusted talent partner for startups, enterprises, and multinational organizations. Delivering premium executive search and scalable staffing solutions worldwide."
      primaryCTA={{
        text: 'Hire Executive Talent',
        href: '#executive-search-section',
      }}
      secondaryCTA={{
        text: 'Scale Your Workforce',
        href: '#global-staffing-section',
      }}
      tertiaryCTA={{
        text: 'Submit Your Resume',
        href: '/job-seekers',
      }}
    />
  </section>

  <section id="about-section" class="scroll-section about-section">
    <div class="section-content">
      <div class="about-strip section-light">
        <div class="section-header">
          <p class="about-kicker">About Hire Ritz</p>
          <h2>Who We Are</h2>
          <p class="section-lead">
            Hire Ritz is a consulting and delivery partner for organizations that want technology
            to create meaningful business impact. We work with decision-makers to solve complex
            transformation challenges with practical, scalable solutions.
          </p>
        </div>

        <div class="section-header about-inner-header">
          <h3>What We Do</h3>
          <p class="section-lead">End-to-end technology capabilities to transform and run your business.</p>
        </div>
        <div class="services-grid">
          {aboutWhatWeDoItems.map((item) => (
            <article class="service-card">
              <div class="service-card-image-wrap">
                <img src={item.image} alt={item.imageAlt} class="service-card-image" width="600" height="340" loading="lazy" />
              </div>
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </article>
          ))}
        </div>

        <div class="section-header about-inner-header">
          <h3>Why Clients Choose Hire Ritz</h3>
          <p class="section-lead">A balanced blend of advisory strength and delivery discipline.</p>
        </div>
        <div class="about-diff-grid">
          {aboutDifferentiators.map((item) => (
            <article class="about-diff-card">
              <div class="about-diff-card-image-wrap">
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  class="about-diff-card-image"
                  width="800"
                  height="500"
                  loading="lazy"
                />
              </div>
              <div class="about-diff-card-body">
                <h3 class="about-diff-card-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="section-header about-inner-header">
          <h3>Our Engagement Model</h3>
          <p class="section-lead">A clear, repeatable approach designed for predictable outcomes.</p>
        </div>
        <div class="about-engagement-grid" aria-label="Engagement model steps">
          {aboutEngagementModel.map((item) => (
            <article class="about-engagement-card">
              <div class="about-engagement-card-visual">
                <span class="about-step-badge">{item.step}</span>
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  class="about-engagement-card-image"
                  width="800"
                  height="480"
                  loading="lazy"
                />
              </div>
              <div class="about-engagement-card-body">
                <h3 class="about-engagement-card-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="about-action">
          <a href="/#about-section" class="btn btn-secondary">Learn More About Us</a>
        </div>
      </div>
    </div>
  </section>
  
  <section id="executive-search-section" class="scroll-section executive-section">
    <div class="section-content">
      <div class="about-strip section-light">
        <div class="section-header">
          <p class="about-kicker">Executive Search</p>
          <h2>Executive Search & Leadership Hiring</h2>
          <p class="section-lead">
            Premium consultative approach for finding C-suite and senior leadership talent.
            We combine deep industry expertise with global reach to deliver exceptional executive candidates.
          </p>
        </div>

        <div class="executive-hero-visual">
          <Picture
            src={executiveHeroImage}
            formats={['avif', 'webp', 'jpeg']}
            widths={[720, 1080, 1440]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 92vw, 980px"
            alt="Executive leadership meeting with strategic planning discussion"
            loading="lazy"
            class="media"
          />
        </div>

        <div class="section-header about-inner-header">
          <h3>Our Approach</h3>
          <p class="section-lead">Partnership, rigor, and global reach at every stage.</p>
        </div>
        <p class="executive-intro-block">
          Our executive search methodology is built on decades of experience placing senior leaders across
          industries and geographies. We understand that executive hiring requires more than matching
          skills—it is about finding leaders who align with your culture, vision, and strategic goals.
        </p>

        <div class="about-diff-grid">
          {executiveApproachItems.map((item) => (
            <article class="about-diff-card">
              <div class="about-diff-card-image-wrap">
                {item.isLocal ? (
                  <Picture
                    src={item.image}
                    formats={['avif', 'webp', 'jpeg']}
                    widths={[480, 720, 960]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    alt={item.imageAlt}
                    loading="lazy"
                    class="about-diff-card-image"
                  />
                ) : (
                  <img
                    src={item.image}
                    alt={item.imageAlt}
                    class="about-diff-card-image"
                    width="800"
                    height="500"
                    loading="lazy"
                  />
                )}
              </div>
              <div class="about-diff-card-body">
                <h3 class="about-diff-card-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="section-header about-inner-header">
          <h3>Leadership Levels We Serve</h3>
          <p class="section-lead">From the C-suite to director-level leadership across functions.</p>
        </div>
        <div class="about-engagement-grid" aria-label="Leadership levels">
          {executiveRoleLevels.map((item) => (
            <article class="about-engagement-card">
              <div class="about-engagement-card-visual">
                <span class="about-step-badge exec-role-badge">{item.badge}</span>
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  class="about-engagement-card-image"
                  width="800"
                  height="480"
                  loading="lazy"
                />
              </div>
              <div class="about-engagement-card-body">
                <h3 class="about-engagement-card-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="about-action">
          <a href="/executive-search" class="btn btn-primary">Explore Executive Search</a>
        </div>
      </div>
    </div>
  </section>
  
  <section id="global-staffing-section" class="scroll-section staffing-section">
    <div class="section-content">
      <div class="about-strip section-light">
        <div class="section-header">
          <p class="about-kicker">Global Staffing</p>
          <h2>Global Staffing & Volume Hiring Solutions</h2>
          <p class="section-lead">
            High-volume, scalable staffing solutions designed for fast-growing organizations.
            Our process-driven approach delivers quality talent at scale across global markets.
          </p>
        </div>

        <div class="staffing-hero-visual">
          <Picture
            src={staffingHeroImage}
            formats={['avif', 'webp', 'jpeg']}
            widths={[720, 1080, 1440]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 92vw, 980px"
            alt="Global staffing operations and large scale hiring strategy session"
            loading="lazy"
            class="media"
          />
        </div>

        <div class="section-header about-inner-header">
          <h3>Why Choose Our Volume Staffing Services?</h3>
          <p class="section-lead">Speed, quality, and scale—without compromising candidate experience.</p>
        </div>
        <p class="staffing-intro-block">
          When you need to scale quickly, traditional recruitment methods fall short. Our volume hiring
          solutions are built for speed, quality, and scale, enabling organizations to build teams of 50,
          200, or 1000+ professionals efficiently.
        </p>

        <div class="about-diff-grid">
          {staffingWhyItems.map((item) => (
            <article class="about-diff-card">
              <div class="about-diff-card-image-wrap">
                {item.isLocal ? (
                  <Picture
                    src={item.image}
                    formats={['avif', 'webp', 'jpeg']}
                    widths={[480, 720, 960]}
                    sizes="(max-width: 768px) 100vw, 33vw"
                    alt={item.imageAlt}
                    loading="lazy"
                    class="about-diff-card-image"
                  />
                ) : (
                  <img
                    src={item.image}
                    alt={item.imageAlt}
                    class="about-diff-card-image"
                    width="800"
                    height="500"
                    loading="lazy"
                  />
                )}
              </div>
              <div class="about-diff-card-body">
                <h3 class="about-diff-card-title">{item.title}</h3>
                <p>{item.desc}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="section-header about-inner-header">
          <h3>How We Engage</h3>
          <p class="section-lead">Flexible models aligned to your hiring volume and timeline.</p>
        </div>
        <div class="about-engagement-grid" aria-label="Staffing engagement models">
          {staffingDeliveryModels.map((item) => (
            <article class="about-engagement-card">
              <div class="about-engagement-card-visual">
                <span class="about-step-badge exec-role-badge">{item.badge}</span>
                <img
