---
import PageLayout from '../layouts/PageLayout.astro';
import { Picture } from 'astro:assets';
import Hero from '../components/Hero.astro';
import ContactContent from '../components/ContactContent.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import ClientLogos from '../components/ClientLogos.astro';
import { generateServiceSchema } from '../utils/schema';
import executiveHeroImage from '../assets/images/executive-hero.jpg';
import executiveProcessImage from '../assets/images/executive-process.jpg';
import executiveGlobalImage from '../assets/images/executive-global.jpg';
import staffingHeroImage from '../assets/images/staffing-hero.jpg';
import staffingWorkflowImage from '../assets/images/staffing-workflow.jpg';
import staffingScaleImage from '../assets/images/staffing-scale.jpg';

const seo = {
  title: 'Global Recruitment & Staffing Solutions',
  description: 'Trusted global talent partner delivering premium executive search and scalable staffing solutions across India, North America, Europe, Middle East, and APAC.',
  keywords: 'global recruitment, executive search, leadership hiring, volume staffing, talent acquisition, global staffing solutions',
  canonical: '/',
};

const executiveSearchSchema = generateServiceSchema({
  name: 'Executive Search & Leadership Hiring',
  description: 'Premium consultative executive search services for C-suite and senior leadership positions across global markets.',
  provider: {
    name: 'Hire Ritz',
    url: 'https://hireritz.com',
  },
  areaServed: ['India', 'North America', 'Europe', 'Middle East', 'APAC'],
  serviceType: 'Executive Recruitment',
});

const globalStaffingSchema = generateServiceSchema({
  name: 'Global Staffing & Volume Hiring',
  description: 'High-volume, scalable staffing solutions for fast-growing organizations requiring bulk talent acquisition.',
  provider: {
    name: 'Hire Ritz',
    url: 'https://hireritz.com',
  },
  areaServed: ['India', 'North America', 'Europe', 'Middle East', 'APAC'],
  serviceType: 'Volume Recruitment',
});

const homeFAQs = [
  {
    question: 'What is the difference between executive search and volume staffing?',
    answer: 'Executive search focuses on finding C-suite and senior leadership positions through a consultative, personalized approach. Volume staffing is designed for high-volume, process-driven bulk hiring needs, typically for mid-level positions across multiple roles simultaneously.',
  },
  {
    question: 'Which regions do you serve?',
    answer: 'We serve clients and candidates across India, North America, Europe, Middle East, and APAC regions, providing global talent solutions with local expertise.',
  },
  {
    question: 'What industries do you specialize in?',
    answer: 'We cover IT, Non-IT, Healthcare, Pharmaceuticals, BFSI, Retail, Manufacturing, and Telecommunications industries, with deep expertise in each vertical.',
  },
  {
    question: 'How long does the executive search process take?',
    answer: 'Executive search timelines vary based on role complexity and market conditions, typically ranging from 8-16 weeks for C-suite positions. We work closely with clients to establish realistic timelines and deliver exceptional candidates.',
  },
  {
    question: 'Can you handle bulk hiring requirements?',
    answer: 'Yes, our volume staffing solutions are designed for organizations needing to scale quickly. We can handle hundreds of positions simultaneously with our process-driven approach and global talent network.',
  },
];

const aboutWhatWeDoItems = [
  { title: 'Digital transformation', desc: 'We help you define and execute technology-led change - modernizing operations, customer experience, and product delivery.', image: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&q=80', imageAlt: 'Digital transformation' },
  { title: 'Cloud & infrastructure', desc: 'We design, migrate, and optimize cloud and hybrid infrastructure so you can scale with confidence.', image: 'https://images.unsplash.com/photo-1544197150-b99a580bb7a8?w=600&q=80', imageAlt: 'Cloud and infrastructure' },
  { title: 'Software & product development', desc: 'We build and evolve custom software and digital products using modern engineering and product practices.', image: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=600&q=80', imageAlt: 'Software development' },
  { title: 'Data, security & compliance', desc: 'We help you leverage data safely - with the right security, compliance, and analytics in place.', image: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?w=600&q=80', imageAlt: 'Data and security' },
];

