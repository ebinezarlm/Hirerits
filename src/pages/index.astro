const industryEngagementHighlights = [
  {
    badge: 'Exec',
    title: 'Executive & leadership',
    desc: 'C-suite and senior leadership searches aligned to sector norms, regulation, and organizational culture.',
    image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=800&q=80',
