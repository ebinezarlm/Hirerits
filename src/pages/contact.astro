---
import PageLayout from '../layouts/PageLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactContent from '../components/ContactContent.astro';
import { generateBreadcrumbSchema } from '../utils/schema';

const seo = {
  title: 'Contact Us - IT Consultancy | Hire Ritz',
  description: 'Get in touch with Hire Ritz for technology consulting, digital transformation, cloud, and software solutions. We serve clients globally.',
  keywords: 'contact hire ritz, IT consultancy contact, technology consulting',
  canonical: '/contact',
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://hireritz.com/' },
  { name: 'Contact', url: 'https://hireritz.com/contact' },
]);
---

<PageLayout
  title={seo.title}
  description={seo.description}
  keywords={seo.keywords}
  canonical={seo.canonical}
  schema={[breadcrumbSchema]}
>
  <PageHero
    title="Contact Us"
    lead="Have a technology or digital transformation challenge? Tell us about your goals and we'll get back to you."
    image="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=800&q=80"
    imageAlt="Contact and communication"
  />

  <ContactContent />
</PageLayout>
