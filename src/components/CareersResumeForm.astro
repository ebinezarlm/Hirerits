---
/** CV upload panel for the Careers page (drag-and-drop, validation-friendly). */
---

<div class="resume-panel" id="resume-form">
  <div class="resume-panel__header">
    <div class="resume-panel__icon" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="40" height="40" rx="12" fill="url(#resumeGrad)"/>
        <path d="M22 12h-8a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V18l-6-6Z" stroke="#fff" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M22 12v6h6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M14 22h12M14 26h8" stroke="#fff" stroke-width="1.5" stroke-linecap="round" opacity="0.85"/>
        <defs>
          <linearGradient id="resumeGrad" x1="8" y1="4" x2="36" y2="36" gradientUnits="userSpaceOnUse">
            <stop stop-color="#0f4c81"/>
            <stop offset="1" stop-color="#0ea5e9"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div>
      <h2 class="resume-panel__title">Submit your CV</h2>
      <p class="resume-panel__subtitle">
        Secure upload · Reviewed by our talent team · Response within 2–3 business days
      </p>
    </div>
  </div>

  <ul class="resume-panel__trust" aria-label="What to expect">
    <li>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
      Confidential
    </li>
    <li>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg>
      Global roles
    </li>
    <li>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      No fees
    </li>
  </ul>

  <form class="resume-form" data-validate data-form-type="resume">
    <div class="form-row form-row--2">
      <div class="form-group">
        <label for="js-name">Full name <span class="req">*</span></label>
        <input type="text" id="js-name" name="name" required autocomplete="name" placeholder="e.g. Alex Morgan" />
      </div>
      <div class="form-group">
        <label for="js-email">Work email <span class="req">*</span></label>
        <input type="email" id="js-email" name="email" required autocomplete="email" placeholder="you@company.com" />
      </div>
    </div>

    <div class="form-row form-row--2">
      <div class="form-group">
        <label for="js-phone">Phone</label>
        <input type="tel" id="js-phone" name="phone" autocomplete="tel" placeholder="+1 · include country code" />
      </div>
      <div class="form-group">
        <label for="js-current-role">Current title</label>
        <input type="text" id="js-current-role" name="current_role" placeholder="e.g. Senior Product Manager" />
      </div>
    </div>

    <div class="form-row form-row--2">
      <div class="form-group">
        <label for="js-experience">Years of experience</label>
        <select id="js-experience" name="experience">
          <option value="">Select range</option>
          <option value="0-2">0–2 years</option>
          <option value="3-5">3–5 years</option>
          <option value="6-10">6–10 years</option>
          <option value="11-15">11–15 years</option>
          <option value="15+">15+ years</option>
        </select>
      </div>
      <div class="form-group">
        <label for="js-industry">Industry focus</label>
        <select id="js-industry" name="industry">
          <option value="">Select</option>
          <option value="it">IT & technology</option>
          <option value="healthcare">Healthcare</option>
          <option value="pharma">Pharma</option>
          <option value="bfsi">BFSI</option>
          <option value="retail">Retail</option>
          <option value="manufacturing">Manufacturing</option>
          <option value="telecom">Telecom</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>

    <div class="form-group form-group--upload">
      <span class="label-block" id="cv-label">Resume / CV <span class="req">*</span></span>
      <div
        class="cv-dropzone"
        data-cv-dropzone
        role="group"
        aria-labelledby="cv-label"
      >
        <input
          type="file"
          id="js-resume"
          name="resume"
          accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
          required
          data-max-bytes="5242880"
          class="cv-dropzone__input"
          tabindex="-1"
        />
        <button type="button" class="cv-dropzone__hit" data-cv-browse>
          <span class="cv-dropzone__graphic" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="24" r="22" fill="#e0f2fe" opacity="0.9"/>
              <path d="M24 14v14m0 0 4-4m-4 4-4-4" stroke="#0f4c81" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M16 30h16" stroke="#0ea5e9" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="cv-dropzone__text">
            <strong>Drag & drop your CV here</strong>
            <span class="cv-dropzone__hint">or <em>browse files</em> — PDF, Word (DOC/DOCX)</span>
          </span>
          <span class="cv-dropzone__limit">Maximum file size 5 MB</span>
        </button>
        <div class="cv-dropzone__file" data-cv-filename hidden>
          <span class="cv-dropzone__file-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
          </span>
          <span class="cv-dropzone__file-name" data-cv-name></span>
          <button type="button" class="cv-dropzone__remove" data-cv-remove aria-label="Remove file">Remove</button>
        </div>
      </div>
      <p class="form-hint">Prefer PDF for consistent formatting across our review tools.</p>
    </div>

    <div class="form-group">
      <label for="js-message">Cover note <span class="optional">(optional)</span></label>
      <textarea
        id="js-message"
        name="message"
        rows="4"
        placeholder="Location preference, notice period, target role, or links (e.g. LinkedIn)…"
      ></textarea>
    </div>

    <button type="submit" class="btn btn-primary resume-form__submit">
      <span>Submit application</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </button>
  </form>
</div>

<script>
  function initCvDropzones() {
    document.querySelectorAll('[data-cv-dropzone]').forEach((zone) => {
      const input = zone.querySelector('input[type="file"]');
      const btn = zone.querySelector('[data-cv-browse]');
      const fileRow = zone.querySelector('[data-cv-filename]');
      const nameEl = zone.querySelector('[data-cv-name]');
      const removeBtn = zone.querySelector('[data-cv-remove]');
      const maxBytes = parseInt(input?.getAttribute('data-max-bytes') || '5242880', 10);

      if (!input || !btn) return;

      const syncState = () => {
        const f = input.files?.[0];
        if (f && fileRow && nameEl) {
          nameEl.textContent = f.name;
          fileRow.hidden = false;
          btn.classList.add('cv-dropzone__hit--has-file');
        } else if (fileRow && nameEl) {
          nameEl.textContent = '';
          fileRow.hidden = true;
          btn.classList.remove('cv-dropzone__hit--has-file');
        }
      };

      btn.addEventListener('click', () => input.click());

      input.addEventListener('change', () => {
        const f = input.files?.[0];
        if (f && f.size > maxBytes) {
          input.value = '';
          syncState();
          input.dispatchEvent(new Event('change', { bubbles: true }));
          alert('Please choose a file under 5 MB.');
          return;
        }
        syncState();
      });

      removeBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        input.value = '';
        syncState();
        input.focus();
      });

      ['dragenter', 'dragover'].forEach((ev) => {
        zone.addEventListener(ev, (e) => {
          e.preventDefault();
          e.stopPropagation();
          zone.classList.add('cv-dropzone--active');
        });
      });
      ['dragleave', 'drop'].forEach((ev) => {
        zone.addEventListener(ev, (e) => {
          e.preventDefault();
          e.stopPropagation();
          zone.classList.remove('cv-dropzone--active');
        });
      });
      zone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        if (!dt?.files?.length) return;
        const file = dt.files[0];
        if (file.size > maxBytes) {
          alert('Please choose a file under 5 MB.');
          return;
        }
        const accept = (input.getAttribute('accept') || '').split(',').map((s) => s.trim());
        const ok =
          !accept.length ||
          accept.some((a) => {
            if (a.startsWith('.')) return file.name.toLowerCase().endsWith(a.toLowerCase());
            return file.type === a;
          });
        if (!ok) {
          alert('Please upload a PDF or Word document.');
          return;
        }
        try {
          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(file);
          input.files = dataTransfer.files;
        } catch {
          return;
        }
        syncState();
        input.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCvDropzones);
  } else {
    initCvDropzones();
  }
</script>

<style>
  .resume-panel {
    background: linear-gradient(165deg, var(--color-surface-elevated) 0%, var(--color-bg-light) 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-lg);
    position: sticky;
    top: calc(var(--header-height) + var(--spacing-md));
  }

  .resume-panel__header {
    display: flex;
    gap: var(--spacing-md);
    align-items: flex-start;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .resume-panel__icon {
    flex-shrink: 0;
  }

  .resume-panel__title {
    font-family: var(--font-display);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: 0 0 var(--spacing-xs);
    line-height: var(--line-height-tight);
  }

  .resume-panel__subtitle {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-lighter);
    line-height: var(--line-height-relaxed);
    max-width: 32ch;
  }

  .resume-panel__trust {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .resume-panel__trust li {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-light);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--spacing-xs) var(--spacing-md);
  }

  .resume-panel__trust svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .form-row {
    display: grid;
    gap: var(--spacing-md);
  }

  @media (min-width: 480px) {
    .form-row--2 {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-group {
    margin-bottom: var(--spacing-lg);
  }

  .form-group label,
  .label-block {
    display: block;
    margin-bottom: var(--spacing-xs);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .req {
    color: var(--color-primary);
  }

  .optional {
    font-weight: var(--font-weight-normal);
    color: var(--color-text-lighter);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-base);
    font-family: inherit;
    background: var(--color-bg);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-lighter);
    opacity: 1;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.12);
  }

  .form-group input.error,
  .form-group select.error,
  .form-group textarea.error {
    border-color: var(--color-error);
  }

  .form-hint {
    margin: var(--spacing-sm) 0 0;
    font-size: var(--font-size-xs);
    color: var(--color-text-lighter);
  }

  .form-group--upload {
    margin-bottom: var(--spacing-lg);
  }

  .cv-dropzone {
    position: relative;
  }

  .cv-dropzone__input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    opacity: 0;
  }

  .cv-dropzone__hit {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-sm);
    width: 100%;
    margin: 0;
    padding: var(--spacing-xl) var(--spacing-lg);
    border: 2px dashed rgba(15, 76, 129, 0.35);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, rgba(224, 242, 254, 0.35) 0%, var(--color-bg) 100%);
    cursor: pointer;
    font: inherit;
    color: inherit;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .cv-dropzone__hit:hover,
  .cv-dropzone__hit:focus-visible {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(15, 76, 129, 0.1);
    outline: none;
  }

  .cv-dropzone--active .cv-dropzone__hit {
    border-color: var(--color-accent);
    background: rgba(224, 242, 254, 0.55);
  }

  .cv-dropzone__input.error ~ .cv-dropzone__hit {
    border-color: var(--color-error);
    background: rgba(254, 226, 226, 0.25);
  }

  .cv-dropzone__hit--has-file {
    padding: var(--spacing-md);
    border-style: solid;
    border-color: rgba(15, 76, 129, 0.2);
  }

  .cv-dropzone__graphic {
    display: block;
  }

  .cv-dropzone__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .cv-dropzone__text strong {
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .cv-dropzone__hint {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
  }

  .cv-dropzone__hint em {
    font-style: normal;
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
  }

  .cv-dropzone__limit {
    font-size: var(--font-size-xs);
    color: var(--color-text-lighter);
  }

  .cv-dropzone__file {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    padding: var(--spacing-md);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .cv-dropzone__file-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .cv-dropzone__file-name {
    flex: 1;
    min-width: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cv-dropzone__remove {
    flex-shrink: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cv-dropzone__remove:hover,
  .cv-dropzone__remove:focus-visible {
    color: var(--color-primary-dark);
    outline: none;
  }

  .resume-form__submit {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-xl);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--spacing-sm);
  }

  .resume-form__submit svg {
    transition: transform var(--transition-fast);
  }

  .resume-form__submit:hover svg,
  .resume-form__submit:focus-visible svg {
    transform: translateX(3px);
  }

  @media (max-width: 1024px) {
    .resume-panel {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .resume-panel {
      padding: var(--spacing-lg);
      border-radius: var(--radius-xl);
    }

    .resume-panel__header {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
