---
interface Props {
  title?: string;
}

const { title = 'Trusted by Leading Organizations' } = Astro.props;

const partners = [
  { name: 'Enterprise & Technology', image: 'https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=600&q=80', imageAlt: 'Enterprise technology' },
  { name: 'Healthcare & Life Sciences', image: 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?w=600&q=80', imageAlt: 'Healthcare' },
  { name: 'Financial Services', image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&q=80', imageAlt: 'Financial services' },
  { name: 'Retail & E‑commerce', image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&q=80', imageAlt: 'Retail and e-commerce' },
  { name: 'Manufacturing & Logistics', image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=600&q=80', imageAlt: 'Manufacturing' },
  { name: 'Global Brands', image: 'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=600&q=80', imageAlt: 'Global organizations' },
];
---

<section class="client-logos-section">
  <div class="container">
    {title && <h2 class="client-logos-title">{title}</h2>}
    <div class="client-logos-grid">
      {partners.map((partner) => (
        <div class="client-logo-card">
          <div class="service-card-image-wrap">
            <img
              src={partner.image}
              alt={partner.imageAlt}
              class="service-card-image"
              width="600"
              height="340"
              loading="lazy"
            />
          </div>
          <h3 class="client-logo-card-label">{partner.name}</h3>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .client-logos-section {
    padding: var(--section-padding-y) 0;
    background: var(--color-bg);
  }
  
  .client-logos-title {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
    color: var(--color-text);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
  }
  
  .client-logos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl);
  }
  
  .client-logo-card {
    padding: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }
  
  .client-logo-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
  }
  
  .client-logo-card .service-card-image-wrap {
    aspect-ratio: 16 / 9;
  }
  
  .client-logo-card .service-card-image {
    transition: transform var(--transition-slow);
  }
  
  .client-logo-card:hover .service-card-image {
    transform: scale(1.03);
  }
  
  .client-logo-card-label {
    margin: 0;
    padding: var(--spacing-lg) var(--spacing-xl);
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    text-align: center;
  }
  
  @media (max-width: 768px) {
    .client-logos-section {
      padding: var(--section-padding-y-mobile) 0;
    }

    .client-logos-title {
      margin-bottom: var(--spacing-xl);
      font-size: var(--font-size-xl);
      padding: 0 var(--spacing-xs);
    }

    .client-logos-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-md);
    }
  }

  @media (max-width: 480px) {
    .client-logos-grid {
      grid-template-columns: 1fr;
    }

    .client-logo-card-label {
      padding: var(--spacing-md) var(--spacing-lg);
      font-size: var(--font-size-sm);
    }
  }
</style>
