---
const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
const navItems = isHomePage
  ? [
      { href: '#hero', label: 'Home', sectionId: 'hero' },
      { href: '#about-section', label: 'About', sectionId: 'about-section' },
      { href: '#executive-search-section', label: 'Executive Search', sectionId: 'executive-search-section' },
      { href: '#global-staffing-section', label: 'Global Staffing', sectionId: 'global-staffing-section' },
      { href: '#industries-section', label: 'Industries', sectionId: 'industries-section' },
      { href: '#testimonials-section', label: 'Testimonials', sectionId: 'testimonials-section' },
      { href: '#faq-section', label: 'FAQ', sectionId: 'faq-section' },
      { href: '#careers-section', label: 'Careers', sectionId: 'careers-section' },
      { href: '#contact-section', label: 'Contact', sectionId: 'contact-section' },
    ]
  : [
      { href: '/', label: 'Home' },
      { href: '/#about-section', label: 'About' },
      { href: '/#industries-section', label: 'Industries' },
      { href: '/careers', label: 'Careers' },
      { href: '/contact', label: 'Contact' },
    ];

function isActive(href: string): boolean {
  if (isHomePage) {
    return href === '#hero';
  }
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
}
---

<header class="header" id="header">
  <nav class="nav" aria-label="Main navigation">
    <div class="container">
      <div class="nav-wrapper">
        <a href="/" class="logo" aria-label="Hire Ritz Home">
          <img
            class="logo-mark"
            src="/images/hire-ritz-logo.png"
            alt=""
            width="200"
            height="220"
            decoding="async"
            fetchpriority="high"
          />
        </a>
        
        <button
          class="mobile-menu-toggle"
          type="button"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="main-menu"
          id="menu-toggle"
        >
          <span class="sr-only">Menu</span>
          <span class="hamburger-line" aria-hidden="true"></span>
          <span class="hamburger-line" aria-hidden="true"></span>
          <span class="hamburger-line" aria-hidden="true"></span>
        </button>
        
        <ul class="nav-menu" id="main-menu" role="menubar">
          {navItems.map((item) => (
            <li role="none">
              <a
                href={item.href}
                class={`nav-link ${isActive(item.href) ? 'active' : ''}`}
                role="menuitem"
                data-section={item.sectionId}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>
</header>

<!-- Mobile / tablet: highlighted bar at bottom while scrolling (logo + menu mirror top) -->
<div class="header-bottom-bar" id="header-bottom-bar" aria-hidden="true">
  <div class="container header-bottom-bar__inner">
    <a href="/" class="logo logo--bottom" aria-label="Hire Ritz Home">
      <img
        class="logo-mark"
        src="/images/hire-ritz-logo.png"
        alt=""
        width="200"
        height="220"
        decoding="async"
      />
    </a>
    <button
      class="mobile-menu-toggle mobile-menu-toggle--bottom"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="main-menu"
      id="menu-toggle-bottom"
    >
      <span class="sr-only">Menu</span>
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
      <span class="hamburger-line" aria-hidden="true"></span>
    </button>
  </div>
</div>

<script>
  const navMenu = document.getElementById('main-menu');
  const menuToggles = Array.from(
    document.querySelectorAll<HTMLButtonElement>('#menu-toggle, #menu-toggle-bottom')
  );
  const bottomBar = document.getElementById('header-bottom-bar');

  function setMenuOpen(open: boolean) {
    if (!navMenu) return;
    navMenu.classList.toggle('open', open);
    menuToggles.forEach((btn) => {
      btn.setAttribute('aria-expanded', String(open));
      btn.classList.toggle('active', open);
    });
    document.body.classList.toggle('nav-menu-open', open);
  }

  function isMenuTarget(node: EventTarget | null) {
    if (!node || !(node instanceof Node)) return false;
    return menuToggles.some((btn) => btn.contains(node)) || (navMenu && navMenu.contains(node));
  }

  menuToggles.forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      setMenuOpen(!isExpanded);
    });
  });

  document.addEventListener('click', (e) => {
    if (!isMenuTarget(e.target)) {
      setMenuOpen(false);
    }
  });

  navMenu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => setMenuOpen(false));
  });

  const SCROLL_SHOW_BOTTOM = 96;
  const mqCompact = window.matchMedia('(max-width: 1024px)');

  function updateScrollNav() {
    const compact = mqCompact.matches;
    const showBottom = compact && window.scrollY > SCROLL_SHOW_BOTTOM;
    document.documentElement.classList.toggle('scroll-nav-active', showBottom);
    if (bottomBar) {
      bottomBar.setAttribute('aria-hidden', String(!showBottom));
    }
    if (header) {
      header.classList.toggle('scrolled', !compact && window.scrollY > 80);
    }
  }

  if (typeof mqCompact.addEventListener === 'function') {
    mqCompact.addEventListener('change', updateScrollNav);
  } else {
    mqCompact.addListener(updateScrollNav);
  }
  window.addEventListener('scroll', updateScrollNav, { passive: true });
  updateScrollNav();

  const header = document.getElementById('header');

  // Homepage scroll-spy: mark nav item for the visible section
  const sectionLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]'));
  if (sectionLinks.length > 0) {
    const sections = sectionLinks
      .map((link) => document.getElementById(link.dataset.section || ''))
      .filter((section): section is HTMLElement => Boolean(section));

    const setActiveSection = (sectionId: string) => {
      sectionLinks.forEach((link) => {
        const isActiveLink = link.dataset.section === sectionId;
        link.classList.toggle('active', isActiveLink);
        if (isActiveLink) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const updateActiveByScroll = () => {
      const headerOffset = header ? header.offsetHeight + 28 : 100;
      const currentY = window.scrollY + headerOffset;
      const nearPageBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 8;

      let activeSectionId = sections[0]?.id;
      for (const section of sections) {
        if (section.offsetTop <= currentY) {
          activeSectionId = section.id;
        } else {
          break;
        }
      }

      if (nearPageBottom && sections.length > 0) {
        activeSectionId = sections[sections.length - 1].id;
      }

      if (activeSectionId) {
        setActiveSection(activeSectionId);
      }
    };

    sectionLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const sectionId = link.dataset.section;
        if (sectionId) {
          setActiveSection(sectionId);
        }
      });
    });

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateActiveByScroll();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateActiveByScroll);
    window.addEventListener('hashchange', updateActiveByScroll);
    updateActiveByScroll();
  }
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: var(--z-sticky);
    background: #f5f5f5;
    border-bottom: 1px solid rgba(15, 76, 129, 0.12);
    transition: background var(--transition-base), box-shadow var(--transition-base);
  }

  .header.scrolled {
    box-shadow: var(--shadow-md);
    background: #f0f0f2;
  }

  /* Mobile / tablet: no fill on top bar — highlight appears on bottom bar while scrolling */
  @media (max-width: 1024px) {
    .header {
      background: transparent;
      border-bottom: none;
      box-shadow: none;
    }

    .header.scrolled {
      background: transparent;
      box-shadow: none;
    }

    .header .logo-mark {
      filter: drop-shadow(0 1px 2px rgb(15 23 42 / 0.12))
        drop-shadow(0 2px 8px rgb(15 23 42 / 0.08));
    }

    .header .hamburger-line {
      box-shadow: 0 1px 2px rgb(15 23 42 / 0.15);
    }
  }

  /* Highlighted bottom bar (compact) — same logo + menu */
  .header-bottom-bar {
    display: none;
  }

  @media (max-width: 1024px) {
    .header-bottom-bar {
      display: block;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: var(--z-sticky);
      background: var(--color-bg);
      border-top: 1px solid var(--color-border);
      box-shadow:
        0 -4px 6px rgb(15 23 42 / 0.06),
        0 -12px 32px rgb(15 23 42 / 0.1);
      padding-top: 10px;
      padding-bottom: max(10px, env(safe-area-inset-bottom));
      transform: translate3d(0, 110%, 0);
      transition: transform 0.32s ease, visibility 0.32s ease;
      visibility: hidden;
      pointer-events: none;
    }

    :global(html.scroll-nav-active) .header-bottom-bar {
      transform: translate3d(0, 0, 0);
      visibility: visible;
      pointer-events: auto;
    }

    :global(html.scroll-nav-active) :global(body) {
      padding-bottom: calc(72px + env(safe-area-inset-bottom));
    }

    :global(body.nav-menu-open) {
      overflow: hidden;
      touch-action: none;
    }

    .nav-menu.open {
      position: fixed;
      inset: 0;
      top: 0;
      max-height: none !important;
      z-index: var(--z-modal);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding-top: max(var(--spacing-xl), env(safe-area-inset-top));
      padding-bottom: max(var(--spacing-xl), env(safe-area-inset-bottom));
      background: #f5f5f5;
      border-top: none;
      box-shadow: none;
    }

    .header-bottom-bar__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--spacing-md);
    }

    .header-bottom-bar .logo-mark {
      height: 44px;
      max-height: 44px;
      max-width: min(132px, 46vw);
    }

    .header-bottom-bar .mobile-menu-toggle {
      display: flex;
    }
  }

  .nav {
    position: relative;
  }
  
  .nav-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) 0;
    min-height: var(--header-height);
  }
  
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover {
    text-decoration: none;
    opacity: 0.92;
  }

  /* Portrait brand mark (graphic + wordmark) */
  .logo-mark {
    display: block;
    height: 72px;
    width: auto;
    max-height: 72px;
    max-width: min(200px, 42vw);
    object-fit: contain;
    object-position: left center;
    flex: 0 0 auto;
  }
  
  .nav-menu {
    display: flex;
    list-style: none;
    gap: var(--spacing-lg);
    margin: 0;
    padding: 0;
  }
  
  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    padding: var(--spacing-sm) var(--spacing-md);
    position: relative;
    border-radius: var(--radius-full);
    transition: color var(--transition-fast), background-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  
  .nav-link:hover,
  .nav-link:focus {
    color: var(--color-primary-dark);
    background: rgba(15, 76, 129, 0.14);
    text-decoration: none;
  }
  
  .nav-link.active {
    color: #ffffff;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    box-shadow: 0 4px 10px rgb(15 76 129 / 0.28);
    font-weight: var(--font-weight-semibold);
  }
  
  .nav-link.active::after {
    content: none;
  }
  
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    border-radius: var(--radius-md);
    -webkit-tap-highlight-color: transparent;
  }

  .mobile-menu-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
  
  .hamburger-line {
    display: block;
    width: 100%;
    height: 3px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
    transform-origin: center;
  }
  
  .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
    transform: translateY(8px) rotate(45deg);
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
    opacity: 0;
  }

  .mobile-menu-toggle.active .hamburger-line:nth-child(4) {
    transform: translateY(-8px) rotate(-45deg);
  }
  
  @media (max-width: 1024px) {
    /* Compact bar: don’t force desktop min-height; equal vertical padding + centered row */
    .nav-wrapper {
      min-height: 0;
      padding: 12px 0;
      align-items: center;
    }

    .logo {
      align-items: center;
      min-width: 0;
    }

    .mobile-menu-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      align-self: center;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: #f5f5f5;
      border-top: 1px solid rgba(15, 76, 129, 0.12);
      padding: var(--spacing-sm) 0;
      gap: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
      z-index: var(--z-dropdown);
    }
    
    .nav-menu.open {
      max-height: min(85vh, 640px);
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      box-shadow: var(--shadow-lg);
    }
    
    .nav-menu li {
      border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }
    
    .nav-menu li:last-child {
      border-bottom: none;
    }
    
    .nav-link {
      display: flex;
      align-items: center;
      padding: var(--spacing-md) var(--spacing-lg);
      min-height: 48px;
    }

    .logo-mark {
      height: 52px;
      max-height: 52px;
      max-width: min(150px, 44vw);
    }
  }

  @media (max-width: 480px) {
    .nav-wrapper {
      padding: 10px 0 12px;
    }

    .logo-mark {
      height: 44px;
      max-height: 44px;
      max-width: min(132px, 46vw);
    }
  }

  :global(body) {
    padding-top: var(--header-height);
  }

  /* Match body offset to compact header whenever hamburger layout is active */
  @media (max-width: 1024px) {
    :global(body) {
      padding-top: var(--header-height-mobile);
    }
  }
</style>
