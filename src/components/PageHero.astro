---
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  title: string;
  lead?: string;
  image?: string;
  imageAlt?: string;
  /** Visible trail; last item is usually current page (omit href). */
  breadcrumbItems?: Array<{ label: string; href?: string }>;
}

const { title, lead, image, imageAlt = '', breadcrumbItems } = Astro.props;
---

<section class="page-hero-wrap">
  <div class="container">
    {breadcrumbItems && breadcrumbItems.length > 0 && <Breadcrumbs items={breadcrumbItems} />}
    <div class="page-hero-inner">
      {image && (
        <div class="page-hero-image-wrap">
          <img
            src={image}
            alt={imageAlt}
            class="page-hero-image"
            loading="eager"
            width="640"
            height="360"
          />
        </div>
      )}
      <div class="page-hero">
        <h1>{title}</h1>
        {lead && <p class="section-lead">{lead}</p>}
      </div>
    </div>
  </div>
</section>

<style>
  .page-hero-inner {
    display: grid;
    gap: var(--spacing-2xl);
    align-items: center;
  }
  .page-hero-image-wrap {
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    aspect-ratio: 16 / 9;
    max-height: 360px;
  }
  .page-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (min-width: 768px) {
    .page-hero-inner {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--spacing-4xl);
    }
    .page-hero-inner:has(.page-hero-image-wrap) .page-hero {
      order: 2;
    }
    .page-hero-inner:has(.page-hero-image-wrap) .page-hero-image-wrap {
      order: 1;
    }
  }
  @media (max-width: 767px) {
    .page-hero-image-wrap {
      max-height: 220px;
    }

    .page-hero-inner {
      gap: var(--spacing-xl);
    }
  }
</style>
