---
interface Props {
  /** Use '-standalone' on the dedicated contact page so IDs stay unique if both appear. */
  idSuffix?: string;
}

const { idSuffix = '' } = Astro.props;
---

<div class="contact-grid">
  <div class="contact-form-section">
    <h2>Send a message</h2>
    <form class="contact-form" data-validate data-form-type="contact">
      <div class="form-group">
        <label for={`name${idSuffix}`}>Full name *</label>
        <input type="text" id={`name${idSuffix}`} name="name" required />
      </div>
      <div class="form-group">
        <label for={`email${idSuffix}`}>Email *</label>
        <input type="email" id={`email${idSuffix}`} name="email" required />
      </div>
      <div class="form-group">
        <label for={`phone${idSuffix}`}>Phone</label>
        <input type="tel" id={`phone${idSuffix}`} name="phone" />
      </div>
      <div class="form-group">
        <label for={`company${idSuffix}`}>Company</label>
        <input type="text" id={`company${idSuffix}`} name="company" />
      </div>
      <div class="form-group">
        <label for={`inquiry-type${idSuffix}`}>Inquiry type *</label>
        <select id={`inquiry-type${idSuffix}`} name="inquiry_type" required>
          <option value="">Select</option>
          <option value="digital-transformation">Digital Transformation</option>
          <option value="cloud">Cloud & Infrastructure</option>
          <option value="software">Software Development</option>
          <option value="security">Cybersecurity</option>
          <option value="data-analytics">Data & Analytics</option>
          <option value="general">General Inquiry</option>
        </select>
      </div>
      <div class="form-group">
        <label for={`message${idSuffix}`}>Message *</label>
        <textarea id={`message${idSuffix}`} name="message" rows="6" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Send message</button>
    </form>
  </div>
  <div class="contact-info-section">
    <h2>Get in touch</h2>
    <div class="contact-info">
      <div class="info-item">
        <h3>Email</h3>
        <p>
          <a href="mailto:contact@hireritz.com">contact@hireritz.com</a>
        </p>
      </div>
      <div class="info-item">
        <h3>Phone</h3>
        <p>
          <a href="tel:+1234567890">+1 (234) 567-8900</a>
        </p>
      </div>
      <div class="info-item">
        <h3>Office hours</h3>
        <p>Monday - Friday: 9:00 AM - 6:00 PM<br />Saturday: 10:00 AM - 2:00 PM</p>
      </div>
    </div>
    <div class="regions-section">
      <h3>Global offices</h3>
      <ul class="regions-list">
        <li><strong>India:</strong> Mumbai, Bangalore, Delhi</li>
        <li><strong>North America:</strong> New York, San Francisco</li>
        <li><strong>Europe:</strong> London, Frankfurt</li>
        <li><strong>Middle East:</strong> Dubai, Riyadh</li>
        <li><strong>APAC:</strong> Singapore, Sydney</li>
      </ul>
    </div>
  </div>
</div>
